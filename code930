class fulltime extends emp{
    double sal;
    fulltime(double s,String n){
        super(n);
        sal=s;
    }
    @Override
    void calcsal(){
        System.out.println("the salary is:"+sal);
    }
}
class parttime extends emp{
    double rate;
    int hours;
    parttime(String n,double r,int h){
        super(n);
        hours=h;
        rate=r;
    }
     @Override
   void calcsal(){
        System.out.println("the salary is:"+hours*rate);
    }
}
