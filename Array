public class Main {
    public static void main(String[] args) {
        int[] arr = {10, 20, 30, 40, 50};

        // Access element
        System.out.println("First element: " + arr[0]);

        // Loop through array
        for (int i = 0; i < arr.length; i++) {
            System.out.println(arr[i]);
        }
    }
}
