import java.util.concurrent.*;


class producer implements Runnable {

        BlockingQueue<Integer> b;

        producer(BlockingQueue<Integer> buf) {
            b = buf;
        }

        public void run() {
            try {
                for (int i = 1; i <= 5; i++) {
                    b.put(i);
                    System.out.println("Produced :" + i);
                    Thread.sleep(1000);
                }
            } catch (Exception e) {
                System.out.println(e);
            }
        }
    }

    class consumer implements Runnable {

        BlockingQueue<Integer> b;

        consumer(BlockingQueue<Integer> buf) {
            b = buf;
        }
        public void run() {
        try{
                for(int i=1;i<=5;i++){
                   int item = b.take();
                    System.out.println("Consumed:"+item);
                    Thread.sleep(1500);
                }
            }
             catch(Exception e){
                System.out.println(e);
            }
   }
}
public class Main {

    public static void main(String[] args) {
        BlockingQueue<Integer> buffer = new ArrayBlockingQueue<>(3);

        Thread p = new Thread(new producer(buffer));
        Thread c = new Thread(new consumer(buffer));

        p.start();
        c.start();

    }
}
